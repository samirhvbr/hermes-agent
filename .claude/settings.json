{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment_perfil": "PERFIL OPUS-ONLY — Opus 4.8 em tudo, janela 1M explicita via sufixo [1m] no model. NAO adicionar CLAUDE_CODE_DISABLE_1M_CONTEXT aqui: e ela que derruba a janela pra 200K. effortLevel maximo aceito em arquivo e 'xhigh'; 'max' so por sessao (/effort max ou CLAUDE_CODE_EFFORT_LEVEL=max no env).",
  "model": "opus[1m]",
  "effortLevel": "xhigh",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8"
  },
  "permissions": {
    "_comment": "Projeto Python (uv + pytest) que roda como gateway em Docker. O boundary real e o SO (ver SECURITY_GUIDELINES.md) — as regras abaixo evitam acidentes, nao substituem isolamento.",
    "defaultMode": "plan",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(scripts/run_tests.sh:*)",
      "Bash(uv run:*)",
      "Bash(uv pip list:*)",
      "Bash(uv lock:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -c:*)",
      "Bash(ruff:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(mypy:*)",
      "Bash(hermes doctor:*)",
      "Bash(hermes version:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose config:*)",
      "Bash(docker compose build:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.hermes/**)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Bash(docker compose down -v:*)",
      "Bash(docker volume rm:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push * --force*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)",
      "Bash(wget * | bash:*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(uv pip install:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose restart:*)",
      "Bash(./deploy.sh:*)",
      "Bash(gh pr create:*)"
    ]
  }
}
