{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment_perfil": "Fork samirhvbr/hermes-agent — agente Python (CLI + gateway). Opus 4.8, effort max, modo plan. Segredos vivem em ~/.hermes (fora do repo) e sao negados para leitura.",
  "model": "opus",
  "effortLevel": "max",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8"
  },
  "permissions": {
    "_comment": "Projeto Python (uv + pytest) que roda como gateway em Docker. O boundary real e o SO (ver SECURITY_GUIDELINES.md) — as regras abaixo evitam acidentes, nao substituem isolamento.",
    "defaultMode": "plan",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(scripts/run_tests.sh:*)",
      "Bash(uv run:*)",
      "Bash(uv pip list:*)",
      "Bash(uv lock:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -c:*)",
      "Bash(ruff:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(mypy:*)",
      "Bash(hermes doctor:*)",
      "Bash(hermes version:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose config:*)",
      "Bash(docker compose build:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.hermes/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(docker compose down -v:*)",
      "Bash(docker volume rm:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(uv pip install:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose restart:*)",
      "Bash(./deploy.sh:*)",
      "Bash(gh pr create:*)"
    ]
  }
}
